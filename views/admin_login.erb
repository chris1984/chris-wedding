<div class="container" style="max-width: 400px;">
  <h1>Admin</h1>
  <div class="divider"></div>

  <% if @error %>
    <p style="color: #c0392b; margin-bottom: 24px;"><%= @error %></p>
  <% end %>

  <form method="post" action="/admin/login">
    <input type="password" name="password" placeholder="Password" required
      style="width: 100%; padding: 12px 16px; border: 1px solid #E8E0D0; border-radius: 3px; font-family: 'Montserrat', sans-serif; font-size: 14px; font-weight: 300; background: #fff; margin-bottom: 20px; outline: none;">
    <button type="submit" class="btn" style="width: 100%;">Log In</button>
  </form>
</div>
